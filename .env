# 服务配置
APP_NAME=语音聊天服务
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8901

# VAD配置
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION=0.3
VAD_MAX_SPEECH_DURATION=30.0
VAD_MIN_SILENCE_DURATION=0.5

# 音频配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_SAMPLE_WIDTH=2

# ASR配置 - 使用本地Whisper模型
ASR_MODEL=/data/work/public/models/whisper-medium
ASR_LANGUAGE=en



# LLM配置
LLM_API_KEY=EMPTY
LLM_BASE_URL=http://192.168.111.3:8093/v1

# 意图理解配置
INTENT_SYSTEM_PROMPT_PATH=conf/system_prompt_intent.txt

# 回复生成配置
GENERATOR_SYSTEM_PROMPT_PATH=conf/system_prompt_generator.txt

# RAG配置
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.1
# Qdrant配置 - 使用内存模式（开发测试用）
QDRANT_USE_MEMORY=true

# TTS配置
# 语言代码: en-us
TTS_LANGUAGE=en-us
TTS_MODEL_PATH=/data/work/public/models/kokoro-onnx/kokoro-v0_19.fp16.onnx
TTS_VOICE_NAME=af_heart
